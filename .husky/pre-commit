npx lint-staged

# Scan staged .js/.jsx files for potential secrets
SECRETS_PATTERN='SUPABASE_SERVICE_KEY|api_key=|password=|secret=|private_key'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  MATCHES=$(echo "$STAGED_FILES" | xargs grep -lE "$SECRETS_PATTERN" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo ""
    echo "ERROR: Potential secrets detected in staged files:"
    echo "$MATCHES"
    echo ""
    echo "If these are false positives, use git commit --no-verify to bypass."
    exit 1
  fi
fi
